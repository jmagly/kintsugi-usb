#!/bin/bash
# kintsugi-build — single-command wizard for building a personalized Kintsugi
# USB. Central iteration-1 deliverable (ADR-006 §D1); auto-chains the full
# pipeline to a flashable .img.zst (#36).
#
# Pipeline (ADR-008 remaster; supersedes the dead live-build path):
#   1. make-remaster-iso.sh   — remaster the stock Ubuntu ISO (rescue tools +
#                               Kintsugi scripts [+ agentic CLIs] [+ offline AI])
#   2. make-ventoy-image.sh   — assemble a Ventoy .img (bootloader + persistence
#                               + the Kintsugi ISO [+ rescue ISOs])           (#34/#42)
#   3. create-image.sh        — compress to <name>.img.zst + .sha256
#
# Usage:
#   ./scripts/kintsugi-build                         Interactive TUI (default)
#   ./scripts/kintsugi-build --from-profile <file>   Replay a saved profile
#                                                    (interactive confirm before build)
#   ./scripts/kintsugi-build --non-interactive <file>  Replay with NO confirm
#   ./scripts/kintsugi-build --dry-run [--from-profile <file>]
#                                                    Show choices + chain; exit
#   ./scripts/kintsugi-build --help                  This help
#
# Output (under ~/kintsugi-builds/<build_name>/):
#   build-profile.yaml     Resumable profile
#   build.log              Full build output
#   <build_name>.iso       Remastered Kintsugi live ISO
#   <build_name>-ventoy.img  Assembled Ventoy disk image
#   <build_name>.img.zst + .sha256   Distributable artifact (flash this)
#
# Key env (override defaults):
#   KINTSUGI_BASE_ISO       Stock Ubuntu/Xubuntu live ISO to remaster
#   KINTSUGI_LIVEFS_EDIT    Path to the livefs-edit entry point
#   KINTSUGI_VENTOY_BIN     Path to Ventoy2Disk.sh
#   KINTSUGI_BUILDS_ROOT    Where to create build dirs (default: $HOME/kintsugi-builds)
#
# Widget library: whiptail by default (universal on Ubuntu). Falls back to
# plain prompts when whiptail is absent.

set -euo pipefail

VERSION="0.2.0"
SCHEMA_VERSION=2

# ---------------------------------------------------------------------------
# Paths + defaults
# ---------------------------------------------------------------------------

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SELF_DIR}/.." && pwd)"

USB_TOOLKIT="${REPO_ROOT}/scripts/usb-toolkit"
REMASTER_SCRIPT="${USB_TOOLKIT}/make-remaster-iso.sh"
VENTOY_SCRIPT="${USB_TOOLKIT}/make-ventoy-image.sh"
IMAGE_SCRIPT="${REPO_ROOT}/scripts/create-image.sh"

BUILDS_ROOT="${KINTSUGI_BUILDS_ROOT:-$HOME/kintsugi-builds}"

# Toolchain locations (ADR-008 remaster path).
LIVEFS_EDIT="${KINTSUGI_LIVEFS_EDIT:-$BUILDS_ROOT/_tools/livefs-venv/bin/livefs-edit}"
# Ventoy binary: env, else first match under $BUILDS_ROOT/_ventoy, else PATH.
default_ventoy() {
    [ -n "${KINTSUGI_VENTOY_BIN:-}" ] && { echo "$KINTSUGI_VENTOY_BIN"; return; }
    local v; v=$(find "$BUILDS_ROOT/_ventoy" -name 'Ventoy2Disk.sh' 2>/dev/null | sort | head -1)
    [ -n "$v" ] && { echo "$v"; return; }
    command -v Ventoy2Disk.sh 2>/dev/null || echo ""
}
VENTOY_BIN="$(default_ventoy)"
# Stock base ISO: env, else newest *.iso under $BUILDS_ROOT/_base.
default_base_iso() {
    [ -n "${KINTSUGI_BASE_ISO:-}" ] && { echo "$KINTSUGI_BASE_ISO"; return; }
    find "$BUILDS_ROOT/_base" -maxdepth 1 -name '*.iso' 2>/dev/null | sort | tail -1
}

# Profile fields (populated by interactive prompts or --from-profile)
PROFILE_BUILD_NAME=""
PROFILE_BASE_ISO=""
PROFILE_INCLUDE_AGENTIC=""      # true/false → --with-agentic
PROFILE_INCLUDE_AI_STACK=""     # true/false → --with-ai-stack (Ollama + yq)
PROFILE_PERSISTENCE_GIB=""      # integer (#34 default 32)
PROFILE_MODELS_POST_FLASH=""    # space-separated list (informational)
PROFILE_SIGN_RELEASE=""         # true/false (v1.0 → false)

# Mode flags
MODE_INTERACTIVE=1
MODE_CONFIRM=1
MODE_DRY_RUN=0
PROFILE_INPUT=""

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

c_bold="\033[1m"; c_red="\033[31m"; c_reset="\033[0m"
err()  { echo -e "${c_red}ERROR:${c_reset} $*" >&2; }
warn() { echo -e "${c_red}WARN:${c_reset}  $*" >&2; }
info() { echo "$*"; }
head1() { echo -e "\n${c_bold}== $* ==${c_reset}"; }
die()  { err "$*"; exit 1; }

# ---------------------------------------------------------------------------
# Prerequisite detection
# ---------------------------------------------------------------------------

have_whiptail()     { command -v whiptail &>/dev/null; }
have_mikefarah_yq() { command -v yq &>/dev/null && yq --version 2>&1 | grep -qi mikefarah; }

check_prerequisites() {
    local missing=()
    have_mikefarah_yq || missing+=("mikefarah/yq (see kintsugi-models --help for install)")
    [ -x "$REMASTER_SCRIPT" ] || missing+=("scripts/usb-toolkit/make-remaster-iso.sh (not executable?)")
    [ -x "$VENTOY_SCRIPT" ]   || missing+=("scripts/usb-toolkit/make-ventoy-image.sh (not executable?)")
    [ -x "$IMAGE_SCRIPT" ]    || missing+=("scripts/create-image.sh (not executable?)")
    [ -x "$LIVEFS_EDIT" ]     || missing+=("livefs-edit ($LIVEFS_EDIT) — install per ADR-008, or set KINTSUGI_LIVEFS_EDIT")
    [ -n "$VENTOY_BIN" ] && [ -x "$VENTOY_BIN" ] || missing+=("Ventoy2Disk.sh — set KINTSUGI_VENTOY_BIN or place under $BUILDS_ROOT/_ventoy")
    command -v mksquashfs >/dev/null 2>&1 || missing+=("squashfs-tools (apt: squashfs-tools)")
    command -v xorriso    >/dev/null 2>&1 || missing+=("xorriso (apt: xorriso)")
    command -v zstd       >/dev/null 2>&1 || missing+=("zstd (apt: zstd)")

    if [ ${#missing[@]} -gt 0 ]; then
        err "Missing prerequisites:"
        for m in "${missing[@]}"; do echo "  - $m" >&2; done
        cat >&2 <<HINT

Install the host toolchain:
  sudo apt-get update
  sudo apt-get install -y whiptail squashfs-tools xorriso zstd

Install mikefarah/yq:
  sudo wget -O /usr/local/bin/yq \\
    https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64
  sudo chmod +x /usr/local/bin/yq

livefs-edit + Ventoy: see ADR-008 and docs/build-guide.md.
HINT
        exit 1
    fi

    # Storage: the 6 GB ISO + ~16 GB .img + .img.zst need headroom.
    mkdir -p "$BUILDS_ROOT"
    local avail_gb
    avail_gb=$(df -BG --output=avail "$BUILDS_ROOT" | tail -1 | tr -dc '0-9')
    if [ -n "$avail_gb" ] && [ "$avail_gb" -lt 30 ]; then
        warn "Only ${avail_gb} GB free at $BUILDS_ROOT (recommended: 30+ GB for ISO + .img + .img.zst)"
    fi

    if ! have_whiptail; then
        warn "whiptail not installed — falling back to plain prompts. Install: sudo apt-get install -y whiptail"
    fi
}

# ---------------------------------------------------------------------------
# Prompt helpers — whiptail with plain fallback
# ---------------------------------------------------------------------------

# yes/no prompt. Args: title, message, default (y|n).
ask_yesno() {
    local title=$1 msg=$2 default=${3:-y}
    if have_whiptail; then
        local default_flag=()
        [ "$default" = "n" ] && default_flag=(--defaultno)
        if whiptail --title "$title" "${default_flag[@]}" --yesno "$msg" 15 70; then
            echo "true"
        else
            echo "false"
        fi
        return 0
    fi
    local prompt="[$default]"
    read -rp "$title — $msg ($prompt) " reply
    reply="${reply:-$default}"
    case "${reply,,}" in
        y|yes|true) echo "true" ;;
        *) echo "false" ;;
    esac
}

# Input box. Args: title, message, default.
ask_input() {
    local title=$1 msg=$2 default=$3
    if have_whiptail; then
        whiptail --title "$title" --inputbox "$msg" 12 70 "$default" 3>&1 1>&2 2>&3 || echo "$default"
        return 0
    fi
    read -rp "$title — $msg [$default] " reply
    echo "${reply:-$default}"
}

# ---------------------------------------------------------------------------
# YAML profile I/O (mikefarah yq)
# ---------------------------------------------------------------------------

write_profile() {
    local path=$1
    mkdir -p "$(dirname "$path")"
    local models_yaml
    # shellcheck disable=SC2086
    models_yaml=$(printf '"%s", ' $PROFILE_MODELS_POST_FLASH | sed 's/, $//')

    cat > "$path" <<YAML
# Kintsugi USB build profile — schema v${SCHEMA_VERSION}
schema_version: ${SCHEMA_VERSION}
generated_by: "kintsugi-build ${VERSION}"
generated_at: "$(date -Iseconds)"

build_name: "${PROFILE_BUILD_NAME}"
base_iso: "${PROFILE_BASE_ISO}"
include_agentic: ${PROFILE_INCLUDE_AGENTIC}     # claude-code, codex, opencode, copilot, openclaw, omnius, aider
include_ai_stack: ${PROFILE_INCLUDE_AI_STACK}   # Ollama + mikefarah yq (offline LLM runtime)
persistence_gib: ${PROFILE_PERSISTENCE_GIB}
models_post_flash: [${models_yaml}]
signing:
  enabled: ${PROFILE_SIGN_RELEASE}
  # v1.0 ships sha256-only (ADR-006 §D5). Set enabled: true once v1.1 minisign lands.
YAML
    info "Profile saved: $path"
}

read_profile() {
    local path=$1
    [ -f "$path" ] || die "Profile file not found: $path"
    have_mikefarah_yq || die "mikefarah/yq required to parse profile"

    local sv
    sv=$(yq eval '.schema_version' "$path")
    if [ "$sv" != "$SCHEMA_VERSION" ]; then
        die "Profile schema_version=$sv (expected $SCHEMA_VERSION). Re-create it with this wizard version."
    fi

    PROFILE_BUILD_NAME=$(yq eval '.build_name'        "$path")
    PROFILE_BASE_ISO=$(yq eval '.base_iso'            "$path")
    PROFILE_INCLUDE_AGENTIC=$(yq eval '.include_agentic'  "$path")
    PROFILE_INCLUDE_AI_STACK=$(yq eval '.include_ai_stack' "$path")
    PROFILE_PERSISTENCE_GIB=$(yq eval '.persistence_gib // 32' "$path")
    PROFILE_MODELS_POST_FLASH=$(yq eval '.models_post_flash[]' "$path" 2>/dev/null | tr '\n' ' ' | sed 's/ *$//')
    PROFILE_SIGN_RELEASE=$(yq eval '.signing.enabled' "$path")
    # An empty/null base_iso in the profile falls back to auto-detect.
    # NB: `if` blocks (not `&&`) so a false test isn't the function's exit status
    # — under `set -e` a trailing failed `[ ... ]` would kill the script silently.
    if [ "$PROFILE_BASE_ISO" = "null" ]; then PROFILE_BASE_ISO=""; fi
    if [ -z "$PROFILE_BASE_ISO" ]; then PROFILE_BASE_ISO="$(default_base_iso)"; fi
    return 0
}

# ---------------------------------------------------------------------------
# Interactive flow
# ---------------------------------------------------------------------------

run_interactive() {
    head1 "Kintsugi USB Build Wizard v${VERSION}"
    info "Single-command build for a personalized Kintsugi rescue USB."
    info "Remasters a stock Ubuntu ISO (ADR-008), assembles a Ventoy .img with"
    info "persistence, and packages a flashable .img.zst."
    echo ""

    # 1. Build name
    local default_name
    default_name="kintsugi-v2026.5.0-$(date +%Y%m%d)"
    PROFILE_BUILD_NAME=$(ask_input "Build name" "Short name for this build (used in filenames + output dir)" "$default_name")

    # 2. Base ISO (ADR-008 remaster input)
    local default_iso; default_iso="$(default_base_iso)"
    PROFILE_BASE_ISO=$(ask_input "Base ISO" \
        "Path to the stock Ubuntu/Xubuntu 24.04 live ISO to remaster (download + verify separately)" \
        "$default_iso")

    # 3. Offline AI runtime (the drive's headline feature)
    PROFILE_INCLUDE_AI_STACK=$(ask_yesno "Offline AI (Ollama)" \
        "Pre-install the offline LLM runtime (Ollama + mikefarah yq)?\n\nThis is the drive's headline feature — local inference with no network. Adds ~2.5 GB. Models are NEVER baked; you pull them post-flash (ADR-005)." \
        "y")

    # 4. Agentic CLI platforms
    PROFILE_INCLUDE_AGENTIC=$(ask_yesno "Agentic CLIs" \
        "Pre-install the AIWG-supported agentic coding CLIs?\n\nBakes: claude-code, codex, opencode, copilot, openclaw, omnius (+ aider). Offline-available; you sign in with your own credentials post-flash.\n\n(VS Code/IDE is tracked separately — Gitea #43.)" \
        "y")

    # 5. Persistence size (#34)
    PROFILE_PERSISTENCE_GIB=$(ask_input "Persistence size" \
        "Ventoy persistence size in GiB (holds /data across reboots; #34)" \
        "32")

    # 6. Models (informational — never baked; user pulls post-flash)
    local want_pull_hint
    want_pull_hint=$(ask_yesno "Recommended models" \
        "Model weights are NEVER baked into the image (ADR-005 user-driven loading). Suggest pulling starter models (qwen3.5:4b, qwen3.5:9b) after first boot?" \
        "y")
    if [ "$want_pull_hint" = "true" ]; then
        PROFILE_MODELS_POST_FLASH="qwen3.5:4b qwen3.5:9b"
    else
        PROFILE_MODELS_POST_FLASH=""
    fi

    # 7. Signing (v1.0 default: no, per ADR-006 §D5)
    PROFILE_SIGN_RELEASE=$(ask_yesno "Signing (v1.0: sha256 only)" \
        "Full minisign signing is deferred to v1.1 (ADR-006 §D5). sha256 is always produced.\n\nEnable minisign anyway? (requires minisign + your keypair)" \
        "n")
}

# ---------------------------------------------------------------------------
# Confirmation + build
# ---------------------------------------------------------------------------

resolve_base_iso() {
    [ -z "$PROFILE_BASE_ISO" ] && PROFILE_BASE_ISO="$(default_base_iso)"
    [ -n "$PROFILE_BASE_ISO" ] || die "No base ISO specified (set KINTSUGI_BASE_ISO, place one under $BUILDS_ROOT/_base, or enter a path)."
    [ -r "$PROFILE_BASE_ISO" ] || die "Base ISO not readable: $PROFILE_BASE_ISO"
}

show_summary() {
    head1 "Build plan"
    local agentic_flag="" aistack_flag=""
    [ "$PROFILE_INCLUDE_AGENTIC" = "true" ]  && agentic_flag="--with-agentic"
    [ "$PROFILE_INCLUDE_AI_STACK" = "true" ] && aistack_flag="--with-ai-stack"
    local build_dir="${BUILDS_ROOT}/${PROFILE_BUILD_NAME}"
    cat <<EOF
Build name:        ${PROFILE_BUILD_NAME}
Output dir:        ${build_dir}/
Base ISO:          ${PROFILE_BASE_ISO}
Offline AI:        ${PROFILE_INCLUDE_AI_STACK}   (Ollama + yq)
Agentic CLIs:      ${PROFILE_INCLUDE_AGENTIC}   (claude/codex/opencode/copilot/openclaw/omnius + aider)
Persistence:       ${PROFILE_PERSISTENCE_GIB} GiB
Post-flash models: ${PROFILE_MODELS_POST_FLASH:-<none suggested>}
Signing:           ${PROFILE_SIGN_RELEASE}  (v1.0: sha256 always; minisign in v1.1)

Pipeline that will run:
  1. sudo ${REMASTER_SCRIPT} \\
       --base '${PROFILE_BASE_ISO}' --output '${build_dir}/${PROFILE_BUILD_NAME}.iso' \\
       --scripts-dir '${USB_TOOLKIT}' --livefs-edit '${LIVEFS_EDIT}' ${agentic_flag} ${aistack_flag}
  2. sudo ${VENTOY_SCRIPT} \\
       --kintsugi-iso '${build_dir}/${PROFILE_BUILD_NAME}.iso' \\
       --output '${build_dir}/${PROFILE_BUILD_NAME}-ventoy.img' \\
       --persistence-size ${PROFILE_PERSISTENCE_GIB} --label KINTSUGI --ventoy-bin '${VENTOY_BIN}'
  3. ${IMAGE_SCRIPT} '${build_dir}/${PROFILE_BUILD_NAME}-ventoy.img' \\
       --output-dir '${build_dir}' --name '${PROFILE_BUILD_NAME}'
EOF
}

run_build() {
    resolve_base_iso
    local build_dir="${BUILDS_ROOT}/${PROFILE_BUILD_NAME}"
    mkdir -p "$build_dir"
    local log="${build_dir}/build.log"
    local profile_path="${build_dir}/build-profile.yaml"
    local iso="${build_dir}/${PROFILE_BUILD_NAME}.iso"
    local img="${build_dir}/${PROFILE_BUILD_NAME}-ventoy.img"

    write_profile "$profile_path"

    local agentic_flag=() aistack_flag=()
    [ "$PROFILE_INCLUDE_AGENTIC" = "true" ]  && agentic_flag=(--with-agentic)
    [ "$PROFILE_INCLUDE_AI_STACK" = "true" ] && aistack_flag=(--with-ai-stack)

    if [ "$MODE_DRY_RUN" = "1" ]; then
        info ""
        info "Dry run — not invoking the pipeline. Commands that would run:"
        info ""
        info "  sudo ${REMASTER_SCRIPT} --base '${PROFILE_BASE_ISO}' --output '${iso}' \\"
        info "       --scripts-dir '${USB_TOOLKIT}' --livefs-edit '${LIVEFS_EDIT}' ${agentic_flag[*]} ${aistack_flag[*]}"
        info "  sudo ${VENTOY_SCRIPT} --kintsugi-iso '${iso}' --output '${img}' \\"
        info "       --persistence-size ${PROFILE_PERSISTENCE_GIB} --label KINTSUGI --ventoy-bin '${VENTOY_BIN}'"
        info "  ${IMAGE_SCRIPT} '${img}' --output-dir '${build_dir}' --name '${PROFILE_BUILD_NAME}'"
        return 0
    fi

    head1 "Running build pipeline"
    info "Logging to: $log"
    info "This takes 20-30+ minutes (remaster + ~1.5 GB Ollama download + repack + compress)."
    info "You may be prompted for your sudo password."
    echo ""

    {
        head1 "[1/3] Remaster the stock ISO"
        sudo "$REMASTER_SCRIPT" --base "$PROFILE_BASE_ISO" --output "$iso" \
            --scripts-dir "$USB_TOOLKIT" --livefs-edit "$LIVEFS_EDIT" \
            "${agentic_flag[@]}" "${aistack_flag[@]}"

        head1 "[2/3] Assemble the Ventoy image"
        sudo "$VENTOY_SCRIPT" --kintsugi-iso "$iso" --output "$img" \
            --persistence-size "$PROFILE_PERSISTENCE_GIB" --label KINTSUGI --ventoy-bin "$VENTOY_BIN"

        head1 "[3/3] Package the distributable image"
        "$IMAGE_SCRIPT" "$img" --output-dir "$build_dir" --name "$PROFILE_BUILD_NAME"
    } 2>&1 | tee "$log"

    # Pipe status (not the tee'd exit) — fail if any stage failed.
    local rc=${PIPESTATUS[0]}
    if [ "$rc" -ne 0 ]; then
        err "Build pipeline FAILED (exit $rc). See $log."
        return "$rc"
    fi

    head1 "Build succeeded"
    local zst sha
    zst=$(find "$build_dir" -maxdepth 1 -name "${PROFILE_BUILD_NAME}.img.zst" | head -1)
    if [ -n "$zst" ] && [ -f "${zst%.zst}.zst" ]; then
        sha=$(find "$build_dir" -maxdepth 1 -name "*.sha256" | head -1)
        cat <<EOF

Distributable:  $zst
Checksum:       ${sha:-<none>}
Size:           $(du -h "$zst" | cut -f1)

Flash it to a USB (DESTRUCTIVE — pick the right device; verify by serial!):
  zstd -dc '$zst' | sudo dd of=/dev/sdX bs=4M status=progress oflag=direct conv=fsync

Post-flash, pull models:
EOF
        for m in $PROFILE_MODELS_POST_FLASH; do info "  kintsugi-models pull $m"; done
        info ""
        info "Rescue ISOs (#35) are not yet bundled by default; add with make-ventoy-image.sh --rescue-iso/--rescue-dir."
    else
        warn "Pipeline reported success but ${PROFILE_BUILD_NAME}.img.zst not found in $build_dir"
    fi
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

cmd_help() {
    sed -n '2,38p' "${BASH_SOURCE[0]}" | sed 's/^# \?//'
    cat <<EOF

Flags:
  --from-profile <file>    Replay a saved profile (interactive confirm)
  --non-interactive <file> Replay with no confirmation
  --dry-run                Show the plan + pipeline; do not build
  --help                   This help

Version: ${VERSION}
EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    while [ $# -gt 0 ]; do
        case "$1" in
            --from-profile)    PROFILE_INPUT=$2; MODE_INTERACTIVE=0; MODE_CONFIRM=1; shift 2 ;;
            --non-interactive) PROFILE_INPUT=$2; MODE_INTERACTIVE=0; MODE_CONFIRM=0; shift 2 ;;
            --dry-run)         MODE_DRY_RUN=1; shift ;;
            --help|-h)         cmd_help; exit 0 ;;
            *)                 err "Unknown flag: $1"; cmd_help; exit 2 ;;
        esac
    done

    check_prerequisites

    if [ "$MODE_INTERACTIVE" = "1" ]; then
        run_interactive
    else
        read_profile "$PROFILE_INPUT"
        info "Loaded profile: $PROFILE_INPUT"
    fi

    show_summary

    if [ "$MODE_CONFIRM" = "1" ] && [ "$MODE_DRY_RUN" = "0" ]; then
        local go
        go=$(ask_yesno "Confirm" "Proceed with the build above?" "y")
        [ "$go" = "true" ] || { info "Aborted by user."; exit 0; }
    fi

    run_build
}

main "$@"
