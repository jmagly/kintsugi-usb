# Build artifacts — images and compressed image archives must not be committed
# (publish via Gitea releases instead)
*.img
*.img.zst
*.img.gz
*.img.xz
*.iso
*.sha256

# AIWG — ignore only high-churn runtime subdirs, NOT .aiwg/ itself
.aiwg/working/
.aiwg/ralph/
.aiwg/ralph-external/

# Agentic provider conventional dirs (generated by aiwg use, not authored)
.codex/
.cursor/agents/
.cursor/commands/
.cursor/skills/
.factory/skills/
.factory/rules/
.warp/
.windsurf/agents/
.windsurf/skills/
.windsurf/rules/

# Operator-private fleet topology — never commit to the public toolkit
# (provide your own; see config/fleet-hosts.example)
config/fleet-hosts
config/includes.chroot/etc/kintsugi/fleet-hosts
